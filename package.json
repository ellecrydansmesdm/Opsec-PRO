{
  "name": "opsec-pro",
  "version": "1.2.2",
  "description": "Opsec PRO — Dynamic Discord Automation & Protection Toolkit",
  "repository": "https://github.com/ellecrydansmesdm/opsec-pro.git",
  "main": "dist-electron/main-loader.js",
  "scripts": {
    "dev": "vite",
    "build:client": "tsc && vite build",
    "build:electron": "npx esbuild electron/main.ts --bundle --platform=node --packages=external --minify --outfile=dist-electron/main.js && npx esbuild electron/preload.ts --bundle --platform=node --packages=external --minify --outfile=dist-electron/preload.js",
    "build": "echo Opsec PRO Release && cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build:client && cross-env NODE_OPTIONS=--max-old-space-size=4096 npm run build:electron && npm run obfuscate",
    "obfuscate": "node scripts/obfuscate-renderer.js",
    "dist": "npm run build && node scripts/compile-bytecode.js --clean && electron-builder",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "productName": "Opsec PRO",
    "appId": "com.opsec.pro",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "release"
    },
    "artifactName": "Opsec PRO Setup RELEASE.exe",
    "publish": [
      {
        "provider": "github",
        "owner": "ellecrydansmesdm",
        "repo": "opsec-pro"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "Opsec PRO",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "shortcutName": "Opsec PRO",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "dist-electron/main-loader.js",
      "dist-electron/main.jsc",
      "dist-electron/preload.js",
      "assets/**/*",
      "public/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/*.md",
      "package.json"
    ],
    "afterPack": "./scripts/after-pack.js"
  },
  "keywords": [
    "discord",
    "selfbot",
    "opsec",
    "automation"
  ],
  "author": "ellecrydansmesdm",
  "license": "ISC",
  "dependencies": {
    "bytenode": "^1.6.0",
    "chalk": "^4.1.2",
    "cross-env": "^10.1.0",
    "discord.js-selfbot-v13": "^3.7.1",
    "dotenv": "^17.4.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "proxy-agent": "^8.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "user-agents": "^2.1.27",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^5.4.3",
    "rollup": "^4.60.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.4"
  }
}
